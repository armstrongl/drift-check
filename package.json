{
  "name": "drift-check-monorepo",
  "version": "0.4.0",
  "private": true,
  "license": "MIT",
  "description": "Monorepo for drift-check tool",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --filter @ordomesh/drift-check build",
    "dev": "pnpm --filter @ordomesh/drift-check dev",
    "start": "pnpm --filter @ordomesh/drift-check start",
    "publish": "pnpm --filter @ordomesh/drift-check build && pnpm --filter @ordomesh/drift-check publish"
  },
  "devDependencies": {
    "@types/node": "^24"
  }
}
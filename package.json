{
  "name": "drift-check-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for drift-check tool",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@ordomesh/drift-check",
    "dev": "npm run dev --workspace=@ordomesh/drift-check",
    "start": "npm run start --workspace=@ordomesh/drift-check"
  },
  "devDependencies": {
    "@types/node": "^24"
  }
}